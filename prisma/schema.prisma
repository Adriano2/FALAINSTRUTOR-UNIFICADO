// FalaInstrutor — modelo de dados de produção (PostgreSQL).
// Substitui a persistência em localStorage por um banco compartilhado.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
  COMPANY
  INSTRUCTOR
}

// Tomador do serviço: pessoa física (CPF) ou jurídica (CNPJ).
enum RecipientType {
  PF
  PJ
}

// Situação da Nota Fiscal de Serviço (NFS-e).
enum InvoiceStatus {
  PENDING
  ISSUED
  CANCELED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum TransactionStatus {
  OPEN
  ACTIVE
  CANCELED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
}

// Captação de clientes (landing page de divulgação + agente de IA).
enum LeadType {
  PERSON
  COMPANY
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  DISCARDED
}

// Lead captado na landing de divulgação (formulário ou agente de IA de vendas).
model Lead {
  id            String     @id @default(cuid())
  type          LeadType   @default(PERSON)
  name          String
  email         String?
  phone         String?
  company       String? // razão social (leads de empresa)
  cnpj          String?
  employeeCount Int? // nº de funcionários (empresa)
  interest      String? // curso/treinamento de interesse
  message       String? // mensagem livre ou resumo da conversa com o agente
  source        String     @default("landing") // landing | ai-agent
  status        LeadStatus @default(NEW)
  createdAt     DateTime   @default(now())

  @@index([status])
  @@index([createdAt])
}

model User {
  id           String   @id @default(cuid())
  name         String
  dob          String?
  cpf          String   @unique
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  isActive     Boolean  @default(true)
  avatar       String?
  registeredAt DateTime @default(now())
  asaasCustomerId String?
  company      Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId    String?

  enrollments  Enrollment[]
  transactions Transaction[]
  comments     Comment[]
  examSubmissions ExamSubmission[]
  orders       Order[]
  loginSessions LoginSession[]
}

// Empresa cliente: agrupa funcionários (User.companyId) e tem um painel próprio
// (gestores com role COMPANY) para ver os certificados emitidos da sua equipe.
model Company {
  id        String   @id @default(cuid())
  name      String
  cnpj      String?
  email     String?
  phone     String?
  employeeCount   Int     @default(0) // total de funcionários (obrigatório no cadastro)
  cnae            String? // CNAE principal
  cnaeDescription String?
  riskGrade       Int?    // grau de risco (NR-04): 1 a 4
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Restrição de horário de acesso aos treinamentos pelos funcionários.
  // { enabled, days:[0..6], start:"HH:MM", end:"HH:MM" } (horário de Brasília).
  accessSchedule  Json    @default("{}")

  // Assinatura recorrente (plano corporativo).
  planId               String?
  plan                 Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  subscriptionStatus   String?   // active | trial | canceled
  subscriptionRenewsAt DateTime?
  asaasSubscriptionId  String?

  members   User[]
}

// Parceiro white-label: marca própria aplicada por subdomínio
// (ex.: parceiro.falainstrutor.com.br).
model Partner {
  id             String   @id @default(cuid())
  slug           String   @unique // subdomínio (ex.: "consultoriax")
  name           String
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String   @default("#1E9B46")
  secondaryColor String   @default("#1F2A3A")
  whatsappNumber String?
  email          String?
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
}

// Plano de assinatura corporativa (recorrência mensal).
model Plan {
  id           String   @id @default(cuid())
  name         String
  description  String   @default("")
  priceMonthly Float
  maxEmployees Int? // limite de colaboradores (null = ilimitado)
  features     Json     @default("[]") // string[]
  isActive     Boolean  @default(true)
  highlight    Boolean  @default(false) // plano em destaque na vitrine
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  companies Company[]
}

model Course {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  description      String
  duration         Int
  price            Float
  coverImage       String?
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  modules          String[]
  manualActivities String[]
  modality         String  @default("EaD") // EaD | Semipresencial | Presencial
  validityMonths   Int     @default(12) // validade do certificado em meses (renovação)
  videoUrl         String? // link da vídeo aula (fallback) visível ao aluno
  moduleVideos     Json    @default("[]") // links por módulo (alinhado a "modules")
  documents        Json    @default("[]") // materiais de apoio: [{ name, url }]
  examQuestions    Json    @default("[]") // prova do curso: [{ question, options[], correctIndex }]
  slides           Json    @default("[]") // deck de slides do treinamento: [{ title, bullets[] }]

  instructors     Instructor[]
  enrollments     Enrollment[]
  comments        Comment[]
  examSubmissions ExamSubmission[]
}

model Instructor {
  id           String  @id @default(cuid())
  name         String
  formation    String
  mte          String?
  crea         String? // Registro CREA do instrutor (ex.: "SP-1234567/D"), opcional
  crq          String? // Registro CRQ (Conselho Regional de Química), opcional
  signatureUrl String? // imagem da assinatura (scan), opcional
  icpEnabled   Boolean @default(false) // assinatura digital habilitada para este instrutor

  // Certificado digital do instrutor (assinatura eletrônica / ICP-Brasil).
  // Identidade exibida no bloco de assinatura do certificado emitido:
  digitalCertHolder     String? // titular do certificado (ex.: "ADRIANO A. R. RICARDO:12345678900")
  digitalCertIssuer     String? // Autoridade Certificadora emissora
  digitalCertSerial     String? // número de série do certificado
  digitalCertValidUntil String? // validade (dd/mm/aaaa)
  // Material de assinatura ICP-Brasil (A1). CIFRADO em repouso (AES-256-GCM) e
  // NUNCA retornado pela API — somente gravação. Vazio = assinatura eletrônica.
  digitalCertPfx       String? // conteúdo do .pfx (base64) cifrado
  digitalCertPassword  String? // senha do .pfx cifrada

  course       Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId     String
}

model Enrollment {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId        String
  progress        Int      @default(0)
  startDate       DateTime @default(now())
  examScore       Int?
  passed          Boolean  @default(false)
  released        Boolean  @default(false) // certificado liberado pelo instrutor (gate da emissão)
  releasedAt      DateTime?
  certificateCode String?  @unique
  enrolledAt      DateTime @default(now())

  // Alerta de vencimento já enviado (evita reenvio constante)
  expiryNotifiedAt DateTime?

  // Rastreamento de tempo (auditoria do treinamento)
  firstAccessAt   DateTime? // primeiro acesso à sala de aula
  watchedSeconds  Int       @default(0) // tempo assistido acumulado, em segundos
  examStartedAt   DateTime? // início da prova
  examFinishedAt  DateTime? // finalização da prova

  // Revogação do certificado (2 etapas): solicitação (instrutor/responsável) →
  // revogação definitiva (apenas administrador).
  revocationRequested   Boolean   @default(false)
  revocationRequestedBy String?   // nome de quem solicitou (instrutor/responsável)
  revocationReason      String?   // motivo da solicitação
  revocationRequestedAt DateTime?
  revoked               Boolean   @default(false) // revogação definitiva (admin)
  revokedBy             String?   // administrador que revogou
  revokedAt             DateTime?

  @@unique([userId, courseId])
}

// Registro de logins (auditoria: hora de início de cada acesso por usuário).
model LoginSession {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  loginAt   DateTime @default(now())
  userAgent String?

  @@index([userId])
  @@index([loginAt])
}

model Transaction {
  id           String            @id @default(cuid())
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  courseName   String
  total        Float
  discount     Float             @default(0)
  status       TransactionStatus @default(ACTIVE)
  installments Int               @default(1)
  couponCode   String?
  date         DateTime          @default(now())
}

model Coupon {
  id                 String     @id @default(cuid())
  code               String     @unique
  description        String
  value              Float
  type               CouponType @default(PERCENTAGE)
  isActive           Boolean    @default(true)
  associatedProducts String[]
}

model Comment {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId   String
  text       String
  reply      String?
  isPublic   Boolean  @default(true)
  date       DateTime @default(now())
}

model ContactMessage {
  id      String   @id @default(cuid())
  name    String
  email   String
  phone   String?
  subject String
  message String
  date    DateTime @default(now())
}

model ExamSubmission {
  id       String   @id @default(cuid())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String
  score    Int
  answers  Json
  passed   Boolean
  validatedByInstructor Boolean  @default(false) // prova liberada/validada pelo instrutor
  validatedAt           DateTime?
  date     DateTime @default(now())
}

// Pedido de compra (rastreado até a confirmação do pagamento via webhook).
model Order {
  id         String      @id @default(cuid())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  courseIds  String[]
  total      Float
  discount   Float       @default(0)
  status     OrderStatus @default(PENDING)
  paymentId  String? // id da cobrança no gateway (Asaas)
  paymentUrl String? // invoiceUrl do gateway
  couponCode String?
  createdAt  DateTime    @default(now())
}

// Conteúdo editável do site (notícias, parceiros, páginas, produtos, e-mails)
// guardado como lista JSON por chave. Editável no painel administrativo.
model SiteContent {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

// Configurações globais da aplicação (layout + pagamento) como linha única.
model AppConfig {
  id        String   @id @default("singleton")
  layout    Json
  payment   Json
  updatedAt DateTime @updatedAt
}

// Base de gerenciamento de Nota Fiscal de Serviço (NFS-e). A emissão junto à
// prefeitura/SEFAZ (integração para CPF e CNPJ) será adicionada futuramente;
// por ora os registros são gerenciados manualmente e começam como PENDING.
model ServiceInvoice {
  id            String        @id @default(cuid())
  number        String? // número da NFS-e (preenchido quando emitida)
  series        String?
  recipientType RecipientType @default(PF)
  document      String // CPF ou CNPJ do tomador
  recipientName String // nome ou razão social
  email         String?
  serviceDesc   String // descrição do serviço prestado
  amount        Float
  issueDate     DateTime      @default(now())
  status        InvoiceStatus @default(PENDING)
  orderId       String? // vínculo opcional com um pedido
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

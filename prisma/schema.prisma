// FalaInstrutor — modelo de dados de produção (PostgreSQL).
// Substitui a persistência em localStorage por um banco compartilhado.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
  COMPANY
}

// Tomador do serviço: pessoa física (CPF) ou jurídica (CNPJ).
enum RecipientType {
  PF
  PJ
}

// Situação da Nota Fiscal de Serviço (NFS-e).
enum InvoiceStatus {
  PENDING
  ISSUED
  CANCELED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum TransactionStatus {
  OPEN
  ACTIVE
  CANCELED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
}

model User {
  id           String   @id @default(cuid())
  name         String
  dob          String?
  cpf          String   @unique
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  isActive     Boolean  @default(true)
  avatar       String?
  registeredAt DateTime @default(now())
  asaasCustomerId String?
  company      Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId    String?

  enrollments  Enrollment[]
  transactions Transaction[]
  comments     Comment[]
  examSubmissions ExamSubmission[]
  orders       Order[]
}

// Empresa cliente: agrupa funcionários (User.companyId) e tem um painel próprio
// (gestores com role COMPANY) para ver os certificados emitidos da sua equipe.
model Company {
  id        String   @id @default(cuid())
  name      String
  cnpj      String?
  email     String?
  phone     String?
  employeeCount   Int     @default(0) // total de funcionários (obrigatório no cadastro)
  cnae            String? // CNAE principal
  cnaeDescription String?
  riskGrade       Int?    // grau de risco (NR-04): 1 a 4
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  members   User[]
}

model Course {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  description      String
  duration         Int
  price            Float
  coverImage       String?
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  modules          String[]
  manualActivities String[]
  videoUrl         String? // link da vídeo aula (fallback) visível ao aluno
  moduleVideos     Json    @default("[]") // links por módulo (alinhado a "modules")
  documents        Json    @default("[]") // materiais de apoio: [{ name, url }]
  examQuestions    Json    @default("[]") // prova do curso: [{ question, options[], correctIndex }]

  instructors     Instructor[]
  enrollments     Enrollment[]
  comments        Comment[]
  examSubmissions ExamSubmission[]
}

model Instructor {
  id           String  @id @default(cuid())
  name         String
  formation    String
  mte          String?
  crea         String? // Registro CREA do instrutor (ex.: "SP-1234567/D"), opcional
  crq          String? // Registro CRQ (Conselho Regional de Química), opcional
  signatureUrl String? // imagem da assinatura (scan), opcional
  icpEnabled   Boolean @default(false) // assinatura digital ICP-Brasil habilitada
  course       Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId     String
}

model Enrollment {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId        String
  progress        Int      @default(0)
  startDate       DateTime @default(now())
  examScore       Int?
  passed          Boolean  @default(false)
  certificateCode String?  @unique
  enrolledAt      DateTime @default(now())

  @@unique([userId, courseId])
}

model Transaction {
  id           String            @id @default(cuid())
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  courseName   String
  total        Float
  discount     Float             @default(0)
  status       TransactionStatus @default(ACTIVE)
  installments Int               @default(1)
  couponCode   String?
  date         DateTime          @default(now())
}

model Coupon {
  id                 String     @id @default(cuid())
  code               String     @unique
  description        String
  value              Float
  type               CouponType @default(PERCENTAGE)
  isActive           Boolean    @default(true)
  associatedProducts String[]
}

model Comment {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId   String
  text       String
  reply      String?
  isPublic   Boolean  @default(true)
  date       DateTime @default(now())
}

model ContactMessage {
  id      String   @id @default(cuid())
  name    String
  email   String
  phone   String?
  subject String
  message String
  date    DateTime @default(now())
}

model ExamSubmission {
  id       String   @id @default(cuid())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String
  score    Int
  answers  Json
  passed   Boolean
  date     DateTime @default(now())
}

// Pedido de compra (rastreado até a confirmação do pagamento via webhook).
model Order {
  id         String      @id @default(cuid())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  courseIds  String[]
  total      Float
  discount   Float       @default(0)
  status     OrderStatus @default(PENDING)
  paymentId  String? // id da cobrança no gateway (Asaas)
  paymentUrl String? // invoiceUrl do gateway
  couponCode String?
  createdAt  DateTime    @default(now())
}

// Conteúdo editável do site (notícias, parceiros, páginas, produtos, e-mails)
// guardado como lista JSON por chave. Editável no painel administrativo.
model SiteContent {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

// Configurações globais da aplicação (layout + pagamento) como linha única.
model AppConfig {
  id        String   @id @default("singleton")
  layout    Json
  payment   Json
  updatedAt DateTime @updatedAt
}

// Base de gerenciamento de Nota Fiscal de Serviço (NFS-e). A emissão junto à
// prefeitura/SEFAZ (integração para CPF e CNPJ) será adicionada futuramente;
// por ora os registros são gerenciados manualmente e começam como PENDING.
model ServiceInvoice {
  id            String        @id @default(cuid())
  number        String? // número da NFS-e (preenchido quando emitida)
  series        String?
  recipientType RecipientType @default(PF)
  document      String // CPF ou CNPJ do tomador
  recipientName String // nome ou razão social
  email         String?
  serviceDesc   String // descrição do serviço prestado
  amount        Float
  issueDate     DateTime      @default(now())
  status        InvoiceStatus @default(PENDING)
  orderId       String? // vínculo opcional com um pedido
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

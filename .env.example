# Copie este arquivo para `.env` e preencha os valores reais.
# O `.env` NÃO é versionado (está no .gitignore) e os segredos ficam só no servidor.

# --- Banco de dados (PostgreSQL) ---
# Em produção (Render/Railway), use a URL do Postgres gerenciado.
DATABASE_URL="postgresql://USUARIO:SENHA@HOST:5432/falainstrutor?schema=public"

# --- Autenticação ---
# Segredo usado para assinar os tokens JWT. Gere um valor longo e aleatório.
JWT_SECRET="troque-por-um-valor-longo-e-aleatorio"

# --- Cifragem de segredos em repouso ---
# Chave para cifrar (AES-256-GCM) o certificado .pfx e a senha de cada instrutor
# guardados no banco. Use um valor longo e aleatório. Se vazio, usa o JWT_SECRET.
# ATENÇÃO: trocar esta chave invalida os .pfx já cadastrados (precisam ser reenviados).
CERT_ENC_KEY="troque-por-uma-chave-longa-e-aleatoria"

# --- Tutor de IA (Google Gemini) ---
# Obtenha em https://aistudio.google.com/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# --- Pagamentos (Asaas) ---
# Chave de API do Asaas (use a de SANDBOX para testes). Em Configurações > Integrações.
ASAAS_API_KEY="MY_ASAAS_API_KEY"
# Ambiente: "sandbox" (padrão) ou "production".
ASAAS_ENV="sandbox"
# Token que você define no painel do Asaas ao cadastrar o webhook (valida as notificações).
ASAAS_WEBHOOK_TOKEN="defina-um-token-secreto"

# --- Servidor ---
# Porta do backend (opcional, padrão 8787).
PORT="8787"
# URL pública da aplicação (usada nos retornos de pagamento e no webhook).
PUBLIC_URL="http://localhost:8787"

# --- App Android (Capacitor) ---
# URL ABSOLUTA do backend de produção que o app Android vai consumir.
# Deixe VAZIO para o site (web), onde front e API ficam na mesma origem.
# Para gerar o APK/AAB, defina a URL pública do servidor antes do build, ex.:
#   VITE_API_BASE_URL="https://falainstrutor.onrender.com" npm run cap:sync
VITE_API_BASE_URL=""

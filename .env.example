# Copie este arquivo para `.env` e preencha os valores reais.
# O `.env` NÃO é versionado (está no .gitignore) e a chave fica apenas no servidor.

# GEMINI_API_KEY: obrigatória para habilitar o Tutor de IA (backend).
# Obtenha em https://aistudio.google.com/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: modelo do Gemini usado pelo Tutor (opcional).
GEMINI_MODEL="gemini-2.5-flash"

# PORT: porta do servidor backend (opcional, padrão 8787).
PORT="8787"
